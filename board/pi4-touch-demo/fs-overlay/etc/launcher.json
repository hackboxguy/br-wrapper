{
  "launcher": {
    "title": {
      "text": "Display-Diagnostic-Tool",
      "logo": "/usr/share/icons/company-logo-large.png",
      "logo_size": {
        "width": 200,
        "height": 80
      },
      "layout": "text_only",
      "font_size": 32,
      "color": "#ffffff"
    },
    "window": {
      "width": 2560,
      "height": 1440
    },
    "layout": {
      "type": "grid",
      "columns": 3,
      "rows": 3,
      "spacing": 30,
      "margins": {
        "top": 100,
        "bottom": 100,
        "left": 150,
        "right": 150
      }
    },
    "buttons": [
      {
        "id": "gallery",
        "enabled": true,
        "text": "Photo Gallery",
        "icon": "/usr/share/icons/gallery-large.png",
        "program": "/usr/bin/touch-gallery",
        "arguments": ["/Pictures"],
        "working_directory": "/Pictures",
        "position": {
          "row": 0,
          "column": 0
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#34495E",
        "hover_color": "#2C3E50",
        "border_radius": 20
      },
      {
        "id": "slideshow",
        "enabled": true,
        "text": "Slideshow",
        "icon": "/usr/share/icons/slideshow-large.png",
        "program": "/usr/bin/touch-gallery",
        "arguments": ["/Pictures", "--slideshow", "5"],
        "working_directory": "/Pictures",
        "position": {
          "row": 0,
          "column": 1
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#27AE60",
        "hover_color": "#229954",
        "border_radius": 20
      },
      {
        "id": "test-pictures",
        "enabled": true,
        "text": "Test Pictures",
        "icon": "/usr/share/icons/gallery-large.png",
        "program": "/usr/bin/touch-gallery",
        "arguments": ["/Patterns"],
        "working_directory": "/Patterns",
        "position": {
          "row": 0,
          "column": 2
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#8E4450",
        "hover_color": "#2C3E50",
        "border_radius": 20
      },
      {
        "id": "drawing",
        "enabled": true,
        "text": "Drawing App",
        "icon": "/usr/share/icons/paint-large.png",
        "program": "/usr/lib/qt/examples/widgets/touch/fingerpaint/fingerpaint",
        "arguments": [],
        "working_directory": "/tmp",
        "position": {
          "row": 1,
          "column": 0
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#E74C3C",
        "hover_color": "#C0392B",
        "border_radius": 20
      },
      {
        "id": "pattern-generator",
        "enabled": true,
        "text": "Pattern Generator",
        "icon": "/usr/share/icons/tools-large.png",
        "program": "/usr/bin/disp-tester",
        "arguments": ["--port", "8082"],
        "working_directory": "/tmp",
        "position": {
          "row": 1,
          "column": 1
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#8E44AD",
        "hover_color": "#7D3C98",
        "border_radius": 20
      },
      {
        "id": "video-player",
        "enabled": true,
        "text": "Video Player",
        "icon": "/usr/share/icons/video-large.png",
        "program": "/usr/bin/qt-mpv-wrapper.sh",
        "arguments": ["/Videos", "--port", "8084"],
        "working_directory": "/tmp",
        "position": {
          "row": 1,
          "column": 2
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#E67E22",
        "hover_color": "#D35400",
        "border_radius": 20
      },
      {
        "id": "disp-settings",
        "enabled": true,
        "text": "Display Settings",
        "icon": "/usr/share/icons/tools-large.png",
        "program": "/usr/bin/disp-settings",
        "arguments": [],
        "working_directory": "/tmp",
        "position": {
          "row": 2,
          "column": 0
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 100,
          "height": 100
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#16A085",
        "hover_color": "#1ABC9C",
        "border_radius": 20
      },
      {
        "id": "exit",
        "enabled": true,
        "text": "Exit",
        "icon": "/usr/share/icons/power-off.png",
        "action": "quit",
        "position": {
          "row": 2,
          "column": 2
        },
        "size": {
          "width": 640,
          "height": 200
        },
        "icon_size": {
          "width": 48,
          "height": 48
        },
        "icon_layout": "icon_top",
        "font_size": 30,
        "background_color": "#8E4000",
        "hover_color": "#D32F2F",
        "border_radius": 12
      }
    ]
  }
}
