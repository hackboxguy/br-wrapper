config BR2_PACKAGE_PHOTOQT
    bool "photoqt"
    depends on BR2_PACKAGE_QT5
    select BR2_PACKAGE_QT5DECLARATIVE
    select BR2_PACKAGE_QT5MULTIMEDIA
    select BR2_PACKAGE_QT5IMAGEFORMATS
    select BR2_PACKAGE_QT5QUICKCONTROLS
    select BR2_PACKAGE_QT5QUICKCONTROLS2
    select BR2_PACKAGE_QT5SVG
    select BR2_PACKAGE_QT5BASE_DBUS
    select BR2_PACKAGE_QT5BASE_SQL
    select BR2_PACKAGE_QT5BASE_SQLITE_QT
    select BR2_PACKAGE_QT5BASE_CONCURRENT
    select BR2_PACKAGE_QT5BASE_PRINTSUPPORT
    select BR2_PACKAGE_QT5BASE_XML
    select BR2_PACKAGE_QT5GRAPHICALEFFECTS
    help
      PhotoQt is a fast and highly configurable image viewer with a simple
      and nice interface. It supports touch gestures including pinch-to-zoom
      and swipe navigation.
      
      https://photoqt.org
