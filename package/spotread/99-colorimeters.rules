# udev rules for colorimeter devices used with spotread
# Place this file in package/spotread/99-colorimeters.rules

# X-Rite devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="0765", MODE="0666", GROUP="plugdev"
# X-Rite i1 series
SUBSYSTEM=="usb", ATTRS{idVendor}=="0971", MODE="0666", GROUP="plugdev"
# ColorMunki series  
SUBSYSTEM=="usb", ATTRS{idVendor}=="085c", MODE="0666", GROUP="plugdev"
# Datacolor Spyder series
SUBSYSTEM=="usb", ATTRS{idVendor}=="085c", ATTRS{idProduct}=="0200", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTRS{idVendor}=="085c", ATTRS{idProduct}=="0400", MODE="0666", GROUP="plugdev"
# Klein K10-A
SUBSYSTEM=="usb", ATTRS{idVendor}=="0c40", MODE="0666", GROUP="plugdev"
# Image Engineering devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="2457", MODE="0666", GROUP="plugdev"
