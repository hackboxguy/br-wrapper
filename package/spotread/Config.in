config BR2_PACKAGE_SPOTREAD
	bool "spotread"
	depends on BR2_USE_MMU # fork()
	depends on BR2_TOOLCHAIN_HAS_THREADS
	select BR2_PACKAGE_LIBUSB
	select BR2_PACKAGE_XORG7
	select BR2_PACKAGE_XLIB_LIBX11
	help
	  Real ArgyllCMS spotread extracted from Debian package.
	  Includes full color measurement functionality for i1Display Pro
	  and other colorimeters. Console-only, minimal X11 dependency.

comment "spotread needs a toolchain w/ threads"
	depends on BR2_USE_MMU
	depends on !BR2_TOOLCHAIN_HAS_THREADS
